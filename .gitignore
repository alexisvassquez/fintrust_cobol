# FinTrust COBOL .gitignore
# ==== Ignore compiled binaries ====
/bin/

# ==== Compiled shared objects ====
/lib/

# ==== Compiled shared objects (GnuCOBOL modules) ====
*.so

# ==== OS-specific ====
.DS_Store
Thumbs.db

# ==== Backup or temp files ====
*.bak
*.tmp
*.swp
*~

# ==== Logs ====
*.log

# ==== COBOL Intermediate files ====
*.o
*.lst
*.mod
*.exe

# ==== IDE/project files ====
.vscode/
.idea/
*.code-workspace
